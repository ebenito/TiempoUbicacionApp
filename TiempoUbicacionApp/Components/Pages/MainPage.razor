@page "/"
@using TiempoUbicacionApp.Models
@using TiempoUbicacionApp.Services
@using TiempoUbicacionApp.Helpers
@inject IAlertService AlertService
@inject ITimeZoneService TimeZoneService
@inject GeolocationService GeolocationService
@inject LocationDatabaseService DatabaseService
@inject ISettingsService SettingsService
@implements IAsyncDisposable

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">

    <!-- ── CARD: Fecha y Hora ───────────────────────────────────────── -->
    <MudCard Class="mb-4" Elevation="0">
        <div class="card-header-custom">
            <span class="card-title">
                <span class="card-title-icon">🕒</span>
                Fecha y hora
            </span>
            <span class="badge badge-teal">En vivo</span>
        </div>

        <MudCardContent Class="pt-2 pb-3 px-4">
            <div class="stat-row">
                <span class="stat-label">Fecha</span>
                <span class="stat-value">@fechaActual</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Hora local</span>
                <span class="stat-value data-mono" style="font-size:1.25rem;color:var(--teal-600);">@horaLocal</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Hora UTC</span>
                <span class="stat-value data-mono">@horaUtc
                    <span style="font-size:.75rem;font-family:var(--font-sans);color:var(--slate-400);margin-left:6px;">
                        @offsetFormatted
                    </span>
                </span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Horario</span>
                <MudTooltip Text='@(isDst ? "Horario de ahorro de luz (verano)" : "Horario estándar (invierno)")'>
                    <span class="badge @(isDst ? "badge-teal" : "badge-slate")">
                        @(isDst ? "🌞 Verano DST" : "❄️ Estándar")
                    </span>
                </MudTooltip>
            </div>
        </MudCardContent>
    </MudCard>

    <!-- ── ESTADOS: Error / Loading ───────────────────────────────────── -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Elevation="0"
                  Style="border-radius:10px;border:1px solid #fca5a5;margin-bottom:16px;">
            ⚠️ @errorMessage
        </MudAlert>
    }
    else if (isLoading)
    {
        <MudCard Elevation="0" Class="mb-4">
            <MudCardContent Class="d-flex justify-center align-center py-10">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium" />
                    <MudText Style="font-size:.8rem;color:var(--slate-400);letter-spacing:.05em;text-transform:uppercase;">
                        Obteniendo ubicación…
                    </MudText>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <!-- ── CARD: Ubicación ─────────────────────────────────────────── -->
        <MudCard Class="mb-4" Elevation="0">
            <div class="card-header-custom">
                <span class="card-title">
                    <span class="card-title-icon">📍</span>
                    Ubicación actual
                </span>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               Color="Color.Primary"
                               OnClick="RefreshLocation"
                               Style="margin:-4px -4px -4px 0;" />
            </div>

            <MudCardContent Class="pt-2 pb-3 px-4">
                <!-- Nombre del lugar -->
                <div class="stat-row">
                    <div class="stat-label">Lugar</div>
                    <div class="stat-value data-mono">@locationName</div>
                </div>

                <div class="stat-row">
                    <span class="stat-label">Latitud</span>
                    <span class="stat-value data-mono">@formattedLatitude</span>
                </div>
                <div class="stat-row">
                    <span class="stat-label">Longitud</span>
                    <span class="stat-value data-mono">@formattedLongitude</span>
                </div>
                <div class="stat-row">
                    <span class="stat-label">Zona GMT</span>
                    <span class="stat-value data-mono">GMT @(zona >= 0 ? $"+{zona}" : $"{zona}")</span>
                </div>

                <!-- Mapa -->
                @if (!string.IsNullOrWhiteSpace(mapUrl))
                {
                    <div class="map-container">
                        <iframe width="100%" height="230" frameborder="0"
                                src="@mapUrl" allowfullscreen
                                style="display:block;border:none;">
                        </iframe>
                    </div>
                }
            </MudCardContent>
        </MudCard>
    }

    <!-- ── ACCIONES PRINCIPALES ───────────────────────────────────────── -->
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth
                   OnClick="SaveData"
                   StartIcon="@Icons.Material.Filled.BookmarkAdd"
                   Style="height:44px;font-weight:600;">
            Guardar
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   FullWidth
                   OnClick="ShareData"
                   StartIcon="@Icons.Material.Filled.IosShare"
                   Style="height:44px;font-weight:600;">
            Compartir
        </MudButton>
    </MudStack>

</MudContainer>

@code {
    private string locationName       = string.Empty;
    private string formattedLatitude  = string.Empty;
    private string formattedLongitude = string.Empty;
    private string mapUrl             = string.Empty;
    private string lat = "0", lon = "0";
    private string errorMessage       = string.Empty;
    private bool   isLoading          = true;

    private string horaLocal       = string.Empty;
    private string horaUtc         = string.Empty;
    private string fechaActual     = string.Empty;
    private string offsetFormatted = string.Empty;
    private string tipoHorario     = string.Empty;
    private int    zona            = 0;
    private bool   isDst;

    private CancellationTokenSource _clockCts       = new();
    private CancellationTokenSource _autoRefreshCts = new();
    private int _currentRefreshInterval = -1;
    private int _isAutoRefreshRunning   = 0;

    protected override void OnInitialized()
    {
        _ = RunClockAsync(_clockCts.Token);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var location = await GeolocationService.GetCurrentLocationAsync();
            var culture  = System.Globalization.CultureInfo.InvariantCulture;

            if (location.Lat != 0)
            {
                locationName       = location.Name;
                formattedLatitude  = location.FormattedLatitude;
                formattedLongitude = location.FormattedLongitude;
                zona               = TimeZoneService.GetStandardGMTZone();
                isDst              = TimeZoneService.IsDaylightSavingNow();
                lat                = location.Lat.ToString(culture);
                lon                = location.Lng.ToString(culture);
                mapUrl             = await GetMapUrlAsync(lat, lon, 15, true) ?? string.Empty;
            }
            else
            {
                await SetDefaultLocationAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error: " + ex.Message;
            await AlertService.ShowLongToastAsync(errorMessage);
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await ConfigureAutoRefreshTimerAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await _clockCts.CancelAsync();
        _clockCts.Dispose();
        await _autoRefreshCts.CancelAsync();
        _autoRefreshCts.Dispose();
    }

    private async Task RunClockAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
                await ActualizarDatosAsync();
        }
        catch (OperationCanceledException) { }
    }

    private async Task ActualizarDatosAsync()
    {
        var now    = DateTime.Now;
        var offset = TimeZoneInfo.Local.GetUtcOffset(now);
        horaLocal       = now.ToString("HH:mm:ss");
        horaUtc         = DateTime.UtcNow.ToString("HH:mm:ss");
        fechaActual     = now.ToString("dddd, dd MMMM yyyy");
        offsetFormatted = offset >= TimeSpan.Zero ? $"+{offset:hh\\:mm}" : $"-{offset:hh\\:mm}";
        tipoHorario     = TimeZoneInfo.Local.IsDaylightSavingTime(now)
            ? "Horario de ahorro de luz (verano)" : "Horario estándar (invierno)";
        await InvokeAsync(StateHasChanged);
    }

    private async Task ConfigureAutoRefreshTimerAsync()
    {
        var interval = await SettingsService.GetRefreshIntervalAsync();
        if (interval == _currentRefreshInterval) return;
        await _autoRefreshCts.CancelAsync();
        _autoRefreshCts.Dispose();
        _autoRefreshCts = new CancellationTokenSource();
        _currentRefreshInterval = interval;
        if (interval > 0)
            _ = RunAutoRefreshAsync(interval, _autoRefreshCts.Token);
    }

    private async Task RunAutoRefreshAsync(int seconds, CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(seconds));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (Interlocked.Exchange(ref _isAutoRefreshRunning, 1) == 1) continue;
                try   { await InvokeAsync(async () => await RefreshLocationCoreAsync(false)); }
                finally { Interlocked.Exchange(ref _isAutoRefreshRunning, 0); }
            }
        }
        catch (OperationCanceledException) { }
    }

    private Task RefreshLocation() => RefreshLocationCoreAsync(true);

    private async Task<bool> RefreshLocationCoreAsync(bool showMessages)
    {
        try
        {
            var location = await GeolocationService.GetCurrentLocationAsync(forceNew: true);
            var culture  = System.Globalization.CultureInfo.InvariantCulture;

            if (location.Name == "Error al obtener datos")
            {
                _currentRefreshInterval = 0;
                await _autoRefreshCts.CancelAsync();
            }

            if (location.Lat != 0 && location.Lng != 0)
            {
                locationName       = location.Name ?? locationName;
                formattedLatitude  = location.FormattedLatitude;
                formattedLongitude = location.FormattedLongitude;
                zona               = TimeZoneService.GetStandardGMTZone();
                isDst              = TimeZoneService.IsDaylightSavingNow();
                lat                = location.Lat.ToString(culture);
                lon                = location.Lng.ToString(culture);
                mapUrl             = await GetMapUrlAsync(lat, lon, 15, true) ?? string.Empty;
                await InvokeAsync(StateHasChanged);
                if (showMessages) await AlertService.ShowToastAsync("Ubicación actualizada.");
                return true;
            }

            if (showMessages) await AlertService.ShowLongToastAsync("No se pudo actualizar la ubicación.");
            return false;
        }
        catch (Exception ex)
        {
            errorMessage = "Error al actualizar ubicación: " + ex.Message;
            _currentRefreshInterval = 0;
            await _autoRefreshCts.CancelAsync();
            await AlertService.ShowLongToastAsync(showMessages ? errorMessage : "Se desactivó la actualización automática.");
            await InvokeAsync(StateHasChanged);
            return false;
        }
    }

    private async Task SaveData()
    {
        await DatabaseService.SaveEntryAsync(new LocationEntry
        {
            Date        = DateTime.Now,
            HoraLocal   = horaLocal,
            HoraUtc     = horaUtc,
            FechaActual = fechaActual,
            Desfase     = offsetFormatted,
            TipoHorario = tipoHorario,
            Location    = locationName,
            Latitude    = formattedLatitude,
            Longitude   = formattedLongitude
        });
        await AlertService.ShowToastAsync("✅ Datos guardados correctamente");
    }

    private async Task ShareData()
    {
        string text =
            $"📅 {fechaActual}\n🕒 Local: {horaLocal}  🌍 UTC: {horaUtc} ({offsetFormatted})\n" +
            $"⏱ {tipoHorario}\n📍 {locationName}\n🧭 {formattedLatitude}  {formattedLongitude}";
        try
        {
            await Share.Default.RequestAsync(new ShareTextRequest
                { Title = "Tiempo & Ubicación", Text = text, Subject = "Datos de ubicación" });
        }
        catch
        {
            await Clipboard.SetTextAsync(text);
            await AlertService.ShowToastAsync("Copiado al portapapeles.");
        }
    }

    private Task<string?> GetMapUrlAsync(string la, string lo, int zoom, bool embed) =>
        CoordinatesHelper.GetMapUrlAsync(la, lo, SettingsService, zoom, embed);

    private async Task SetDefaultLocationAsync()
    {
        locationName       = "Casto Celtíbero, Olmeda de Cobeta";
        formattedLatitude  = "40° 51' 33\" N";
        formattedLongitude = "02° 12' 32\" O";
        zona               = TimeZoneService.GetStandardGMTZone();
        isDst              = TimeZoneService.IsDaylightSavingNow();
        mapUrl             = await GetMapUrlAsync("40.8591", "-2.2088", 15, true) ?? string.Empty;
    }
}
