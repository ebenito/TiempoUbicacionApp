@page "/"
@using TiempoUbicacionApp.Models
@using TiempoUbicacionApp.Services
@using TiempoUbicacionApp.Helpers
@using CommunityToolkit.Maui.Alerts
@inject IJSRuntime JS
@inject IAlertService AlertService
@inject ITimeZoneService TimeZoneService
@inject GeolocationService GeolocationService
@inject LocationDatabaseService DatabaseService
@inject ISettingsService SettingsService
@implements IDisposable



<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">

    <!-- Card de Fecha y Hora -->
    <MudCard Class="mb-4" Elevation="2">
        <MudCardHeader>
            <MudText Typo="Typo.h5" Color="Color.Primary">📅 Datos de fecha y hora</MudText>
        </MudCardHeader>
        <MudDivider Class="my-2" />
        <MudCardContent>
            <MudStack Spacing="2">
                <MudText>📅 Fecha: <strong>@fechaActual</strong></MudText>
                <MudText>🕒 Hora Local: <strong>@horaLocal</strong></MudText>
                <MudText>🌍 Hora UTC: <strong>@horaUtc</strong> (Desfase: <strong>@offsetFormatted</strong>)</MudText>
                <MudText>⏱ Horario: <strong>@tipoHorario</strong></MudText>
            </MudStack>
        </MudCardContent>
    </MudCard>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Elevation="2" Dense="false" Class="mb-4">
            ⚠️ @errorMessage
        </MudAlert>
    }
    else if (isLoading)
    {
        <MudPaper Class="d-flex justify-center align-center py-8" Elevation="0">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </MudPaper>
    }
    else
    {
        <!-- Card de Ubicación Actual -->
        <MudCard Class="mb-4" Elevation="2">
            <MudCardHeader>
                <MudText Typo="Typo.h5" Color="Color.Primary">📍 Ubicación actual</MudText>
            </MudCardHeader>
            <MudDivider Class="my-2" />
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body1"><strong>📌 @locationName</strong></MudText>
                    <MudText>Latitud: <strong>@formattedLatitude</strong></MudText>
                    <MudText>Longitud: <strong>@formattedLongitude</strong></MudText>
                    <MudText>Zona GMT: <strong>@zona</strong> | <strong>@(isDst ? "🌞 Horario de verano (DST)" : "❄️ Horario estándar")</strong></MudText>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(mapUrl))
                {
                    <MudPaper Class="mt-4" Style="overflow: hidden; border-radius: 12px;" Elevation="1">
                        <iframe width="100%" height="250" frameborder="0" src="@mapUrl" allowfullscreen style="border: none;"></iframe>
                    </MudPaper>
                }

                <MudStack Row="true" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              FullWidth 
                              OnClick="RefreshLocation"
                              StartIcon="@Icons.Material.Filled.Refresh">
                        Actualizar ubicación
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }

    <!-- Botones de acción principales -->
    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  FullWidth 
                  OnClick="SaveData"
                  StartIcon="@Icons.Material.Filled.Save">
            💾 Guardar
        </MudButton>
        <MudButton Variant="Variant.Outlined" 
                  Color="Color.Secondary" 
                  FullWidth 
                  OnClick="ShareData"
                  StartIcon="@Icons.Material.Filled.Share">
            📤 Compartir
        </MudButton>
    </MudStack>

</MudContainer>


@code {
    string locationName = string.Empty, formattedLatitude = string.Empty, formattedLongitude = string.Empty, mapUrl = string.Empty;
    string lat = "0", lon = "0";

    string errorMessage = string.Empty;
    bool isLoading = true;

    private string horaLocal = string.Empty;
    private string horaUtc = string.Empty;
    private string fechaActual = string.Empty;
    private string offsetFormatted = string.Empty;
    private string tipoHorario = string.Empty;
    private int zona = 0;
    private bool isDst;


    private System.Threading.Timer clockTimer;
    private System.Threading.Timer? autoRefreshTimer;
    private int currentRefreshInterval = -1;
    private int isAutoRefreshRunning;

    protected override void OnInitialized()  
    {  
        clockTimer = new System.Threading.Timer(async _ => await ActualizarDatosAsync(), null, 0, 1000);  
    }  

    protected override async Task OnParametersSetAsync()
    {
        await ConfigureAutoRefreshTimerAsync();
    }

    public void Dispose()
    {
        clockTimer?.Change(Timeout.Infinite, Timeout.Infinite);
        clockTimer?.Dispose();
        StopAutoRefreshTimer();
    }

    private async Task ConfigureAutoRefreshTimerAsync()
    {
        var refreshInterval = await SettingsService.GetRefreshIntervalAsync();

        if (refreshInterval == currentRefreshInterval)
        {
            return;
        }

        StopAutoRefreshTimer();
        currentRefreshInterval = refreshInterval;

        if (refreshInterval <= 0)
        {
            return;
        }

        autoRefreshTimer = new System.Threading.Timer(
            async _ => await AutoRefreshLocationCallbackAsync(),
            null,
            TimeSpan.FromSeconds(refreshInterval),
            TimeSpan.FromSeconds(refreshInterval));
    }

    private void StopAutoRefreshTimer()
    {
        autoRefreshTimer?.Change(Timeout.Infinite, Timeout.Infinite);
        autoRefreshTimer?.Dispose();
        autoRefreshTimer = null;
    }

    private async Task AutoRefreshLocationCallbackAsync()
    {
        if (Interlocked.Exchange(ref isAutoRefreshRunning, 1) == 1)
        {
            return;
        }

        try
        {
            await InvokeAsync(async () => await RefreshLocationCoreAsync(showMessages: false));
        }
        finally
        {
            Interlocked.Exchange(ref isAutoRefreshRunning, 0);
        }
    }

    private async Task ActualizarDatosAsync()
    {
        var now = DateTime.Now;
        var utcNow = DateTime.UtcNow;
        var offset = TimeZoneInfo.Local.GetUtcOffset(now);

        horaLocal = now.ToString("HH:mm:ss");
        horaUtc = utcNow.ToString("HH:mm:ss");
        fechaActual = now.ToString("dddd, dd MMMM yyyy");
        offsetFormatted = offset >= TimeSpan.Zero ? $"+{offset:hh\\:mm}" : $"-{offset:hh\\:mm}";
        tipoHorario = TimeZoneInfo.Local.IsDaylightSavingTime(now) ? "Horario de ahorro de luz (verano)" : "Horario estándar (invierno)";

        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {   
            var location = await GeolocationService.GetCurrentLocationAsync();

            // Usamos InvariantCulture para asegurar que siempre haya puntos decimales
            var culture = System.Globalization.CultureInfo.InvariantCulture;

            if (location.Name != null && location.Lat != 0)
            {
                locationName = location.Name;
                formattedLatitude = location.FormattedLatitude;
                formattedLongitude = location.FormattedLongitude;
                zona = TimeZoneService.GetStandardGMTZone();
                isDst = TimeZoneService.IsDaylightSavingNow();

                lat = location.Lat.ToString(culture);
                lon = location.Lng.ToString(culture);

                // Cálculo del Bounding Box para OSM (Zoom aprox 15)
                // double offset = 0.005;
                // string bbox = $"{(location.Lng - offset).ToString(culture)}%2C" +
                //                 $"{(location.Lat - offset).ToString(culture)}%2C" +
                //                 $"{(location.Lng + offset).ToString(culture)}%2C" +
                //                 $"{(location.Lat + offset).ToString(culture)}";

                // mapUrl = $"https://www.openstreetmap.org/export/embed.html?bbox={bbox}&layer=mapnik&marker={lat}%2C{lon}";
                mapUrl = await GetMapUrlAsync(lat, lon, 15, isEmbedded: true);
            }
            else            
            {
                // Valores por defecto (Casto Celtíbero)
                locationName = "Casto Celtíbero, Olmeda de Cobeta";
                formattedLatitude = "40° 51' 33\" N";
                formattedLongitude = "02° 12' 32\" O";
                zona = TimeZoneService.GetStandardGMTZone();
                isDst = TimeZoneService.IsDaylightSavingNow();

                // Coordenadas fijas para el default
                string defLat = "40.8591";
                string defLon = "-2.2088";
                mapUrl = await GetMapUrlAsync(defLat, defLon, 15, isEmbedded: true);
                // mapUrl = $"https://www.openstreetmap.org/export/embed.html?bbox={defBbox}&layer=mapnik&marker={defLat}%2C{defLon}";
                // mapUrl = $"https://maps.google.com/maps?q={lat},{lon}&z=15&output=embed";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error: " + ex.Message;
            await AlertService.ShowLongToastAsync(errorMessage);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<string> GetMapUrlAsync(string latitude, string longitude, int zoom, bool isEmbedded)
    {
        return await CoordinatesHelper.GetMapUrlAsync(latitude, longitude, zoom, isEmbedded);
    }

    private async Task RefreshLocation()
    {
        await RefreshLocationCoreAsync(showMessages: true);
    }

    private async Task<bool> RefreshLocationCoreAsync(bool showMessages)
    {
        try
        {
            var location = await GeolocationService.GetCurrentLocationAsync(forceNew: true);
            var culture = System.Globalization.CultureInfo.InvariantCulture;

            if (location.Name == "Error al obtener datos")
            {
                StopAutoRefreshTimer();
                currentRefreshInterval = 0;                
            }

            if (location.Lat != 0 && location.Lng != 0)
            {
                locationName = location.Name ?? locationName;
                formattedLatitude = location.FormattedLatitude;
                formattedLongitude = location.FormattedLongitude;
                zona = TimeZoneService.GetStandardGMTZone();
                isDst = TimeZoneService.IsDaylightSavingNow();

                lat = location.Lat.ToString(culture);
                lon = location.Lng.ToString(culture);
                mapUrl = await GetMapUrlAsync(lat, lon, 15, isEmbedded: true);

                await InvokeAsync(StateHasChanged);

                if (showMessages)
                {
                    await AlertService.ShowToastAsync("Ubicación actualizada.");
                }

                return true;
            }

            if (showMessages)
            {
                await AlertService.ShowLongToastAsync("No se pudo actualizar la ubicación.");
            }

            return false;
        }
        catch (Exception ex)
        {
            errorMessage = "Error al actualizar ubicación: " + ex.Message;
            StopAutoRefreshTimer();
            currentRefreshInterval = 0;

            await AlertService.ShowLongToastAsync(
                showMessages
                    ? errorMessage
                    : "Se desactivó la actualización automática por un error al obtener la ubicación.");

            await InvokeAsync(StateHasChanged);
            return false;
        }
    }
   
    async Task SaveData()  
    {  
        await DatabaseService.SaveEntryAsync(new LocationEntry  
        {  
            Date = DateTime.Now,  
            horaLocal = horaLocal,
            horaUtc = horaUtc,
            fechaActual = fechaActual,
            desfase = offsetFormatted,
            tipoHorario = tipoHorario,
            Location = locationName,  
            Latitude = formattedLatitude,  
            Longitude = formattedLongitude  
        });  
            
        await AlertService.ShowToastAsync("Datos guardados correctamente"); 
    }  

    async Task ShareData()
    {
      string text = $"📅 Fecha: {fechaActual}\n🕒 Hora local: {horaLocal}\n🌍 Hora UTC: {horaUtc} (Desfase: {offsetFormatted})\n🕓 Periodo: {tipoHorario}\n📍 Ubicación: {locationName}\n🧭 Lat: {formattedLatitude}, Lon: {formattedLongitude}";

        try
        {
            // Esto abrirá el selector nativo (WhatsApp, Telegram, etc.) directamente
            await Share.Default.RequestAsync(new ShareTextRequest
            {
                Title = "Mis datos de ubicación y tiempo",
                Text = text,
                Subject = "Datos de ubicación" // Útil para apps de Email como Outlook
            });
        }
        catch (Exception ex)
        {
            // Si falla el compartir nativo (ej. el usuario cancela), copiamos al portapapeles
            await Clipboard.SetTextAsync(text);
            await AlertService.ShowToastAsync("Copiado al portapapeles.");
        }
    }

