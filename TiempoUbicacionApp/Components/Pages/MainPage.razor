@page "/"
@using TiempoUbicacionApp.Models
@using TiempoUbicacionApp.Services
@using TiempoUbicacionApp.Helpers
@inject IJSRuntime JS
@inject IAlertService AlertService
@inject ITimeZoneService TimeZoneService
@inject GeolocationService GeolocationService
@inject LocationDatabaseService DatabaseService
@inject ISettingsService SettingsService

@implements IAsyncDisposable

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">

    <!-- Card de Fecha y Hora -->
    <MudCard Class="mb-4" Elevation="2">
        <MudCardHeader>
            <MudText Typo="Typo.h5" Color="Color.Primary">📅 Datos de fecha y hora</MudText>
        </MudCardHeader>
        <MudDivider Class="my-2" />
        <MudCardContent>
            <MudStack Spacing="2">
                <MudText>📅 Fecha: <strong>@fechaActual</strong></MudText>
                <MudText>🕒 Hora Local: <strong>@horaLocal</strong></MudText>
                <MudText>🌍 Hora UTC: <strong>@horaUtc</strong> (Desfase: <strong>@offsetFormatted</strong>)</MudText>
                <MudText>⏱ Horario: <strong>@tipoHorario</strong></MudText>
            </MudStack>
        </MudCardContent>
    </MudCard>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Elevation="2" Dense="false" Class="mb-4">
            ⚠️ @errorMessage
        </MudAlert>
    }
    else if (isLoading)
    {
        <MudPaper Class="d-flex justify-center align-center py-8" Elevation="0">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </MudPaper>
    }
    else
    {
        <MudCard Class="mb-4" Elevation="2">
            <MudCardHeader>
                <MudText Typo="Typo.h5" Color="Color.Primary">📍 Ubicación actual</MudText>
            </MudCardHeader>
            <MudDivider Class="my-2" />
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body1"><strong>📌 @locationName</strong></MudText>
                    <MudText>Latitud: <strong>@formattedLatitude</strong></MudText>
                    <MudText>Longitud: <strong>@formattedLongitude</strong></MudText>
                    <MudText>Zona GMT: <strong>@zona</strong> | <strong>@(isDst ? "🌞 Horario de verano (DST)" : "❄️ Horario estándar")</strong></MudText>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(mapUrl))
                {
                    <MudPaper Class="mt-4" Style="overflow: hidden; border-radius: 12px;" Elevation="1">
                        <iframe width="100%" height="250" frameborder="0" src="@mapUrl"
                                allowfullscreen style="border: none;"></iframe>
                    </MudPaper>
                }

                <MudStack Row="true" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth
                               OnClick="RefreshLocation"
                               StartIcon="@Icons.Material.Filled.Refresh">
                        Actualizar ubicación
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth
                   OnClick="SaveData"
                   StartIcon="@Icons.Material.Filled.Save">
            💾 Guardar
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   FullWidth
                   OnClick="ShareData"
                   StartIcon="@Icons.Material.Filled.Share">
            📤 Compartir
        </MudButton>
    </MudStack>

</MudContainer>

@code {
    // ── Estado de UI ──────────────────────────────────────────────────────
    private string locationName = string.Empty;
    private string formattedLatitude = string.Empty;
    private string formattedLongitude = string.Empty;
    private string mapUrl = string.Empty;
    private string lat = "0", lon = "0";
    private string errorMessage = string.Empty;
    private bool isLoading = true;

    private string horaLocal = string.Empty;
    private string horaUtc = string.Empty;
    private string fechaActual = string.Empty;
    private string offsetFormatted = string.Empty;
    private string tipoHorario = string.Empty;
    private int zona = 0;
    private bool isDst;

    // ── Timers ────────────────────────────────────────────────────────────
    // PeriodicTimer es más seguro que System.Threading.Timer para Blazor:
    // - No necesita bloqueo por concurrencia, el bucle awaita antes de continuar.
    // - Se cancela limpiamente con CancellationToken.
    private CancellationTokenSource _clockCts = new();
    private CancellationTokenSource _autoRefreshCts = new();
    private int _currentRefreshInterval = -1;
    private int _isAutoRefreshRunning = 0;

    // ── Ciclo de vida ─────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        // Lanzamos el reloj en background sin bloquear el render inicial
        _ = RunClockAsync(_clockCts.Token);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var location = await GeolocationService.GetCurrentLocationAsync();
            var culture = System.Globalization.CultureInfo.InvariantCulture;

            if (location.Lat != 0)
            {
                locationName = location.Name;
                formattedLatitude = location.FormattedLatitude;
                formattedLongitude = location.FormattedLongitude;
                zona = TimeZoneService.GetStandardGMTZone();
                isDst = TimeZoneService.IsDaylightSavingNow();
                lat = location.Lat.ToString(culture);
                lon = location.Lng.ToString(culture);
                mapUrl = await GetMapUrlAsync(lat, lon, 15, isEmbedded: true);
            }
            else
            {
                SetDefaultLocation();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error: " + ex.Message;
            await AlertService.ShowLongToastAsync(errorMessage);
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await ConfigureAutoRefreshTimerAsync();
    }

    // ── IAsyncDisposable ──────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        // Cancelar y liberar ambos timers
        await _clockCts.CancelAsync();
        _clockCts.Dispose();

        await _autoRefreshCts.CancelAsync();
        _autoRefreshCts.Dispose();
    }

    // ── Reloj (PeriodicTimer) ─────────────────────────────────────────────

    private async Task RunClockAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
                await ActualizarDatosAsync();
        }
        catch (OperationCanceledException)
        {
            // Normal al destruir el componente
        }
    }

    private async Task ActualizarDatosAsync()
    {
        var now = DateTime.Now;
        var utcNow = DateTime.UtcNow;
        var offset = TimeZoneInfo.Local.GetUtcOffset(now);

        horaLocal = now.ToString("HH:mm:ss");
        horaUtc = utcNow.ToString("HH:mm:ss");
        fechaActual = now.ToString("dddd, dd MMMM yyyy");
        offsetFormatted = offset >= TimeSpan.Zero ? $"+{offset:hh\\:mm}" : $"-{offset:hh\\:mm}";
        tipoHorario = TimeZoneInfo.Local.IsDaylightSavingTime(now)
            ? "Horario de ahorro de luz (verano)"
            : "Horario estándar (invierno)";

        await InvokeAsync(StateHasChanged);
    }

    // ── Auto-refresco (PeriodicTimer) ─────────────────────────────────────

    private async Task ConfigureAutoRefreshTimerAsync()
    {
        var refreshInterval = await SettingsService.GetRefreshIntervalAsync();
        if (refreshInterval == _currentRefreshInterval) return;

        // Cancelar el timer anterior
        await _autoRefreshCts.CancelAsync();
        _autoRefreshCts.Dispose();
        _autoRefreshCts = new CancellationTokenSource();

        _currentRefreshInterval = refreshInterval;

        if (refreshInterval > 0)
            _ = RunAutoRefreshAsync(refreshInterval, _autoRefreshCts.Token);
    }

    private async Task RunAutoRefreshAsync(int intervalSeconds, CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(intervalSeconds));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                // Evitar llamadas solapadas si la geolocalización tarda más que el intervalo
                if (Interlocked.Exchange(ref _isAutoRefreshRunning, 1) == 1) continue;
                try
                {
                    await InvokeAsync(async () => await RefreshLocationCoreAsync(showMessages: false));
                }
                finally
                {
                    Interlocked.Exchange(ref _isAutoRefreshRunning, 0);
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    // ── Ubicación ─────────────────────────────────────────────────────────

    private async Task RefreshLocation()
    {
        await RefreshLocationCoreAsync(showMessages: true);
    }

    private async Task<bool> RefreshLocationCoreAsync(bool showMessages)
    {
        try
        {
            var location = await GeolocationService.GetCurrentLocationAsync(forceNew: true);
            var culture = System.Globalization.CultureInfo.InvariantCulture;

            if (location.Name == "Error al obtener datos")
            {
                await StopAutoRefreshAsync();
            }

            if (location.Lat != 0 && location.Lng != 0)
            {
                locationName = location.Name ?? locationName;
                formattedLatitude = location.FormattedLatitude;
                formattedLongitude = location.FormattedLongitude;
                zona = TimeZoneService.GetStandardGMTZone();
                isDst = TimeZoneService.IsDaylightSavingNow();
                lat = location.Lat.ToString(culture);
                lon = location.Lng.ToString(culture);
                mapUrl = await GetMapUrlAsync(lat, lon, 15, isEmbedded: true);

                await InvokeAsync(StateHasChanged);

                if (showMessages)
                    await AlertService.ShowToastAsync("Ubicación actualizada.");

                return true;
            }

            if (showMessages)
                await AlertService.ShowLongToastAsync("No se pudo actualizar la ubicación.");

            return false;
        }
        catch (Exception ex)
        {
            errorMessage = "Error al actualizar ubicación: " + ex.Message;
            await StopAutoRefreshAsync();

            await AlertService.ShowLongToastAsync(showMessages
                ? errorMessage
                : "Se desactivó la actualización automática por un error.");

            await InvokeAsync(StateHasChanged);
            return false;
        }
    }

    private async Task StopAutoRefreshAsync()
    {
        _currentRefreshInterval = 0;
        await _autoRefreshCts.CancelAsync();
    }

    // ── Guardar y Compartir ───────────────────────────────────────────────

    private async Task SaveData()
    {
        await DatabaseService.SaveEntryAsync(new LocationEntry
        {
            Date = DateTime.Now,
            HoraLocal = horaLocal,
            HoraUtc = horaUtc,
            FechaActual = fechaActual,
            Desfase = offsetFormatted,
            TipoHorario = tipoHorario,
            Location = locationName,
            Latitude = formattedLatitude,
            Longitude = formattedLongitude
        });

        await AlertService.ShowToastAsync("Datos guardados correctamente");
    }

    private async Task ShareData()
    {
        string text =
            $"📅 Fecha: {fechaActual}\n" +
            $"🕒 Hora local: {horaLocal}\n" +
            $"🌍 Hora UTC: {horaUtc} (Desfase: {offsetFormatted})\n" +
            $"🕓 Periodo: {tipoHorario}\n" +
            $"📍 Ubicación: {locationName}\n" +
            $"🧭 Lat: {formattedLatitude}, Lon: {formattedLongitude}";

        try
        {
            await Share.Default.RequestAsync(new ShareTextRequest
            {
                Title = "Mis datos de ubicación y tiempo",
                Text = text,
                Subject = "Datos de ubicación"
            });
        }
        catch
        {
            await Clipboard.SetTextAsync(text);
            await AlertService.ShowToastAsync("Copiado al portapapeles.");
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    /// <summary>
    /// CAMBIO: pasamos SettingsService explícitamente (elimina MauiSettingsService.Current).
    /// </summary>
    private Task<string?> GetMapUrlAsync(string latitude, string longitude, int zoom, bool isEmbedded) =>
        CoordinatesHelper.GetMapUrlAsync(latitude, longitude, SettingsService, zoom, isEmbedded);

    private async Task SetDefaultLocation()
    {
        locationName = "Casto Celtíbero, Olmeda de Cobeta";
        formattedLatitude = "40° 51' 33\" N";
        formattedLongitude = "02° 12' 32\" O";
        zona = TimeZoneService.GetStandardGMTZone();
        isDst = TimeZoneService.IsDaylightSavingNow();
        mapUrl = await GetMapUrlAsync("40.8591", "-2.2088", 15, isEmbedded: true) ?? string.Empty;
    }
}
