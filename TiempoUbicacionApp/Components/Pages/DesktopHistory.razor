@using MudBlazor
@using TiempoUbicacionApp.Helpers
@using TiempoUbicacionApp.Models
@using TiempoUbicacionApp.Services
@inject LocationDatabaseService DatabaseService
@inject IAlertService AlertService
@inject ISettingsService SettingsService

<MudStack Spacing="0">

    <!-- Cabecera de sección -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <span style="width:10px;height:10px;border-radius:50%;background:#14b8a6;display:inline-block;"></span>
            <MudText Typo="Typo.h5" Style="font-weight:700;letter-spacing:-.01em;">Historial</MudText>
            @if (Entries.Any())
            {
                <span class="badge badge-slate">@Entries.Count() registros</span>
            }
        </MudStack>

        <!-- Acciones compactas -->
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="Backup">
                <MudIconButton Icon="@Icons.Material.Filled.CloudUpload"
                               Color="Color.Primary" Size="Size.Small"
                               OnClick="OnBackup" />
            </MudTooltip>
            <MudTooltip Text="Restaurar">
                <MudIconButton Icon="@Icons.Material.Filled.CloudDownload"
                               Color="Color.Success" Size="Size.Small"
                               OnClick="OnRestore" />
            </MudTooltip>
            <MudTooltip Text="Refrescar">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Default" Size="Size.Small"
                               OnClick="OnRefresh" />
            </MudTooltip>
        </MudStack>
    </MudStack>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-10">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
        </MudStack>
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <MudAlert Severity="Severity.Error" Style="border-radius:10px;">@_error</MudAlert>
    }
    else if (!Entries.Any())
    {
        <MudCard Elevation="0" Style="border:1px dashed var(--slate-200);">
            <MudCardContent Class="d-flex justify-center align-center py-10">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <span style="font-size:2rem;opacity:.35;">📭</span>
                    <MudText Style="font-size:.8rem;color:var(--slate-400);letter-spacing:.05em;text-transform:uppercase;">
                        Sin registros guardados
                    </MudText>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <MudTable Items="@Entries" Dense="true" Hover="true"
                  Elevation="0" Striped="false"
                  Style="border-radius:12px;overflow:hidden;border:1px solid var(--slate-200);">
            <HeaderContent>
                <MudTh>Fecha</MudTh>
                <MudTh>Hora local</MudTh>
                <MudTh>UTC</MudTh>
                <MudTh>Horario</MudTh>
                <MudTh>Lugar</MudTh>
                <MudTh>Coordenadas</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Fecha">
                    <span class="data-mono" style="font-size:.8rem;">@context.FechaActual</span>
                </MudTd>
                <MudTd DataLabel="Hora local">
                    <span class="data-mono" style="color:var(--teal-600);font-weight:600;">@context.HoraLocal</span>
                </MudTd>
                <MudTd DataLabel="UTC">
                    <span class="data-mono">@context.HoraUtc</span>
                    <span style="font-size:.72rem;color:var(--slate-400);margin-left:4px;">@context.Desfase</span>
                </MudTd>
                <MudTd DataLabel="Horario">
                    <span class="badge @(context.TipoHorario.Contains("verano") ? "badge-teal" : "badge-slate")"
                          style="font-size:.65rem;">
                        @(context.TipoHorario.Contains("verano") ? "🌞 DST" : "❄️ STD")
                    </span>
                </MudTd>
                <MudTd DataLabel="Lugar">
                    <span style="font-size:.85rem;">@context.Location</span>
                </MudTd>
                <MudTd DataLabel="Coordenadas">
                    @{
                        var hasCoords = !string.IsNullOrEmpty(context.Latitude) &&
                                        !string.IsNullOrEmpty(context.Longitude);
                        _mapUrls.TryGetValue(context.Id, out var mapUrl);
                    }
                    @if (!string.IsNullOrEmpty(mapUrl))
                    {
                        <a href="@mapUrl" target="_blank" class="coord-link">
                            @context.Latitude, @context.Longitude
                        </a>
                    }
                    else if (hasCoords)
                    {
                        <span class="data-mono" style="font-size:.78rem;">
                            @context.Latitude, @context.Longitude
                        </span>
                    }
                    else
                    {
                        <span style="color:var(--slate-400);font-size:.8rem;">—</span>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

</MudStack>

@code {
    [Parameter] public IEnumerable<LocationEntry> Entries { get; set; } = Enumerable.Empty<LocationEntry>();
    [Parameter] public EventCallback OnBackup  { get; set; }
    [Parameter] public EventCallback OnRestore { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }

    private bool   _loading = true;
    private string _error   = string.Empty;
    private Dictionary<int, string> _mapUrls = new();

    protected override async Task OnInitializedAsync()
    {
        try   { await DatabaseService.OpenAsync(); }
        catch (Exception ex)
        {
            _error = "No se pudo cargar el histórico.";
            try { await AlertService.ShowLongToastAsync($"{_error}\n{ex.Message}"); } catch { }
        }
        finally { _loading = false; }
    }

    protected override async Task OnParametersSetAsync()
    {
        _mapUrls = new();
        foreach (var entry in Entries)
        {
            if (string.IsNullOrEmpty(entry.Latitude) || string.IsNullOrEmpty(entry.Longitude)) continue;
            var url = await CoordinatesHelper.GetMapUrlAsync(
                entry.Latitude, entry.Longitude, SettingsService, zoom: 10, isEmbedded: false);
            if (!string.IsNullOrEmpty(url)) _mapUrls[entry.Id] = url;
        }
    }
}
