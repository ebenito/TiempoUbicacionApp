@page "/configuracion"
@using TiempoUbicacionApp.Services
@inject ThemeService ThemeService
@inject ISettingsService SettingsService
@inject IAlertService AlertService

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudCard Elevation="2" Class="p-4">
        <MudCardHeader>
            <MudText Typo="Typo.h5" Color="Color.Primary">⚙️ Configuración de la App</MudText>
        </MudCardHeader>

        <MudDivider Class="my-2" />

        <MudCardContent>
            <!-- Selector de Tema - Switch con cambio inmediato -->
            <MudText Typo="Typo.subtitle2" Class="mb-3">🎨 Tema de la aplicación</MudText>
            <MudStack Row="true" Spacing="2" Class="mb-6">
                <MudButton Variant="@(_isDarkMode ? Variant.Text : Variant.Filled)"
                          Color="Color.Primary"
                          OnClick="@(() => ToggleTheme(false))"
                          FullWidth="true">
                    ☀️ Claro
                </MudButton>
                <MudButton Variant="@(_isDarkMode ? Variant.Filled : Variant.Text)"
                          Color="Color.Primary"
                          OnClick="@(() => ToggleTheme(true))"
                          FullWidth="true">
                    🌙 Oscuro
                </MudButton>
            </MudStack>

            <!-- Intervalo de actualización -->
            <MudSelect T="int"
                       Label="Intervalo de actualización"
                       @bind-Value="_refreshInterval"
                       Variant="Variant.Filled"
                       Class="mb-6">
                <MudSelectItem Value="0">No actualizar automaticamente</MudSelectItem>
                <MudSelectItem Value="15">15 segundos</MudSelectItem>
                <MudSelectItem Value="30">30 segundos</MudSelectItem>
                <MudSelectItem Value="60">1 minuto</MudSelectItem>
                <MudSelectItem Value="120">2 minutos</MudSelectItem>
                <MudSelectItem Value="300">5 minutos</MudSelectItem>
                <MudSelectItem Value="900">15 minutos</MudSelectItem>
                <MudSelectItem Value="1800">30 minutos</MudSelectItem>
                <MudSelectItem Value="3600">60 minutos</MudSelectItem>
            </MudSelect>

            <!-- Proveedor de mapas -->
            <MudSelect T="MapProvider"
                       Label="Proveedor de mapas"
                       @bind-Value="_mapProvider"
                       Variant="Variant.Filled"
                       Class="mb-6">
                <MudSelectItem Value="MapProvider.Google">🗺️ Google Maps</MudSelectItem>
                <MudSelectItem Value="MapProvider.OpenStreetMap">🌍 OpenStreetMap</MudSelectItem>
            </MudSelect>

            <!-- Botones de acción -->
            <MudStack Row="true" Spacing="3" Class="mt-6">
                <MudButton OnClick="GuardarConfiguracion"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Medium"
                           FullWidth="true">
                    💾 Guardar configuración
                </MudButton>
            </MudStack>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private bool _isDarkMode;
    private int _refreshInterval;
    private MapProvider _mapProvider;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isDarkMode = await SettingsService.GetIsDarkModeAsync();
            _refreshInterval = await SettingsService.GetRefreshIntervalAsync();
            _mapProvider = await SettingsService.GetMapProviderAsync();
        }
        catch (Exception ex)
        {
            await AlertService.ShowToastAsync("Error al cargar la configuración: " + ex.Message);
        }
    }

    private async Task ToggleTheme(bool isDark)
    {
        _isDarkMode = isDark;
        ThemeService.SetDarkMode(isDark);
        await AlertService.ShowToastAsync(isDark ? "🌙 Tema oscuro activado" : "☀️ Tema claro activado");
    }

    private async Task GuardarConfiguracion()
    {
        try
        {
            await SettingsService.SetRefreshIntervalAsync(_refreshInterval);
            await SettingsService.SetMapProviderAsync(_mapProvider);
            ThemeService.SetDarkMode(_isDarkMode);

            await AlertService.ShowToastAsync("✅ Configuración guardada correctamente.");
        }
        catch (Exception ex)
        {
            await AlertService.ShowToastAsync("❌ Error al guardar la configuración: " + ex.Message);
        }
    }
}